    bigint id PK
    varchar inspection_no UK
    varchar inspection_type
    bigint work_order_id FK
    bigint inventory_batch_id FK
    bigint product_id FK
    varchar result
  }

  QUALITY_INSPECTION_ITEMS {
    bigint id PK
    bigint quality_inspection_id FK
    varchar check_item
    varchar result
  }

  QUALITY_EXCEPTIONS {
    bigint id PK
    varchar exception_no UK
    bigint quality_inspection_id FK
    varchar category
    varchar severity
    varchar status
  }


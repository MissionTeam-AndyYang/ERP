  }

  DISPATCHES {
    bigint id PK
    varchar dispatch_no UK
    bigint shipment_id FK
    bigint vehicle_id FK
    bigint driver_employee_id FK
    varchar status
  }

  AUDIT_LOGS {
    bigint id PK
    bigint actor_user_id FK
    varchar entity_type
    bigint entity_id
    varchar action
    datetime created_at
  }

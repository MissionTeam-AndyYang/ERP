    bigint id PK
    varchar warehouse_code UK
    varchar warehouse_name
    varchar warehouse_type
  }

  WAREHOUSE_LOCATIONS {
    bigint id PK
    bigint warehouse_id FK
    varchar location_code
    varchar temperature_zone
  }

  VEHICLES {
    bigint id PK
    varchar vehicle_no UK
    bigint driver_employee_id FK
    varchar status
  }

  SALES_ORDERS {
    bigint id PK
    varchar order_no UK
    bigint customer_id FK
    date order_date
    varchar status
  }

  SALES_ORDER_LINES {
    bigint id PK
    bigint sales_order_id FK
    bigint product_id FK
    decimal ordered_qty
    decimal shipped_qty
  }

  PURCHASE_ORDERS {
    bigint id PK
    varchar po_no UK
    bigint supplier_id FK
    date order_date
    varchar status
  }

  PURCHASE_ORDER_LINES {
    bigint id PK
    bigint purchase_order_id FK
    bigint item_id FK
    decimal ordered_qty
    decimal received_qty
  }

  INVENTORY_BATCHES {
    bigint id PK
    varchar batch_no
    bigint item_id FK
    bigint warehouse_location_id FK
    decimal qty_on_hand
    date expiry_date
  }

  INVENTORY_TRANSACTIONS {
    bigint id PK
    varchar transaction_no UK
    varchar transaction_type
    bigint item_id FK
    bigint inventory_batch_id FK
    decimal qty
  }

  WORK_ORDERS {
    bigint id PK
    varchar work_order_no UK
    bigint sales_order_line_id FK
    bigint product_id FK
    bigint bom_header_id FK
    bigint production_line_id FK
    decimal planned_qty
    varchar status
  }

  WORK_ORDER_MATERIALS {
    bigint id PK
    bigint work_order_id FK
    bigint item_id FK
    decimal required_qty
    decimal issued_qty
    decimal consumed_qty
  }

  PRODUCTION_REPORTS {
    bigint id PK
    varchar report_no UK
    bigint work_order_id FK
    decimal good_qty
    decimal defect_qty
    decimal oee
  }


  ROLES {
    bigint id PK
    varchar code UK
    varchar name
  }

  USERS {
    bigint id PK
    varchar username UK
    bigint role_id FK
    bigint employee_id FK
    varchar status
  }

  EMPLOYEES {
    bigint id PK
    varchar employee_no UK
    varchar name
    varchar department
    varchar status
  }

  CUSTOMERS {
    bigint id PK
    varchar customer_no UK
    varchar name
    varchar status
  }

  SUPPLIERS {
    bigint id PK
    varchar supplier_no UK
    varchar name
    varchar status
  }

  ITEMS {
    bigint id PK
    varchar item_code UK
    varchar item_name
    varchar item_type
    varchar uom
    bigint default_supplier_id FK
  }

  PRODUCTS {
    bigint id PK
    varchar product_code UK
    varchar product_name
    varchar uom
    bigint default_bom_id FK
    bigint default_production_line_id FK
  }

  PRODUCT_VERSIONS {
    bigint id PK
    bigint product_id FK
    varchar version_no
    date effective_from
    date effective_to
  }

